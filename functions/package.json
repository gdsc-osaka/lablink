{
    "name": "functions",
    "description": "Cloud Functions for lablink",
    "scripts": {
        "build": "tsc",
        "lint": "tsc --noEmit",
        "fix": "pnpm run lint",
        "serve": "firebase emulators:start --only functions",
        "shell": "firebase functions:shell",
        "start": "npm run serve",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "18"
    },
    "main": "lib/index.js",
    "dependencies": {
        "firebase-admin": "^13.5.0",
        "firebase-functions": "^6.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "typescript": "^5.3.3"
    }
}
